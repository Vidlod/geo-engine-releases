{
  "name": "geo-engine-desktop",
  "version": "1.9.7",
  "description": "GEO Engine — App de escritorio para maquetación de cursos Moodle (UDES)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:web": "cd ../web && npm run build",
    "prebuild:mac": "npm run build:web",
    "prebuild:win": "npm run build:web",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "electron-updater": "^6.3.0",
    "express": "^4.21.0",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.2"
  }
}